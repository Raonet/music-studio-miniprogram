<view class="tab-bar">
  <view
    wx:for="{{tabs}}"
    wx:key="path"
    class="tab-item {{selected === index ? 'active' : ''}}"
    bindtap="switchTab"
    data-path="{{item.path}}"
    data-index="{{index}}"
  >
    <image
      class="tab-icon"
      src="{{selected === index ? item.iconActive : item.iconInactive}}"
      mode="aspectFit"
    />
    <text class="tab-label">{{item.label}}</text>
  </view>
</view>
