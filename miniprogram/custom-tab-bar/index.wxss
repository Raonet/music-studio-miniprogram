.tab-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  height: 112rpx;
  background-color: #16161C;
  border-top: 1rpx solid #2E2D35;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  gap: 6rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-label {
  font-size: 20rpx;
  color: #5A5550;
}

.active .tab-label {
  color: #C9A84C;
}
