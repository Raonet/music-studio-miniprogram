<view class="navbar" style="padding-top: {{statusBarHeight}}px;">
  <view class="navbar-inner">
    <view wx:if="{{showBack}}" class="back-btn" bindtap="goBack">
      <image class="back-icon" src="/assets/icons/arrow-left-gold.svg" mode="aspectFit" />
    </view>
    <text class="navbar-title">{{title}}</text>
  </view>
</view>
<view class="navbar-placeholder" style="height: {{statusBarHeight + 56}}px;"></view>
