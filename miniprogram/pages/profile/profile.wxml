<navbar title="我的" showBack="{{false}}"></navbar>

<!-- 新用户注册信息弹层 -->
<view class="register-mask" wx:if="{{showRegisterForm}}">
  <view class="register-panel">
    <text class="register-title">完善个人信息</text>
    <text class="register-desc">首次登录，请填写以下信息完成注册</text>
    <view class="form-item" style="margin-top:40rpx;">
      <input class="form-input" placeholder="请输入您的姓名" placeholder-class="form-placeholder" value="{{registerNickName}}" bindinput="onNickNameInput" />
    </view>
    <view class="form-item" style="margin-top:24rpx;">
      <input class="form-input" placeholder="专长方向（如：钢琴、小提琴）" placeholder-class="form-placeholder" value="{{registerSpecialty}}" bindinput="onSpecialtyInput" />
    </view>
    <button class="login-btn" style="margin-top:48rpx;" bindtap="onCompleteProfile">
      <text class="login-btn-text">完成注册</text>
    </button>
  </view>
</view>

<view class="page">
  <!-- 未登录态 -->
  <block wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <view class="login-icon-wrap">
        <image class="login-icon" src="/assets/icons/music-note-gold.svg" mode="aspectFit" />
      </view>
      <text class="login-title">欢迎使用 Music Studio</text>
      <text class="login-desc">登录后查看个人信息、课时记录和课程安排</text>

      <view class="login-form">
        <view class="form-item">
          <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="form-placeholder" value="{{loginPhone}}" bindinput="onPhoneInput" />
        </view>
        <view class="form-item captcha-row">
          <input class="form-input captcha-input" placeholder="请输入验证码" placeholder-class="form-placeholder" value="{{loginCode}}" bindinput="onCodeInput" />
          <rich-text class="captcha-rich" nodes="{{captchaNodes}}" bindtap="refreshCaptcha"></rich-text>
        </view>
      </view>

      <button class="login-btn" bindtap="onLogin">
        <text class="login-btn-text">登录 / 注册</text>
      </button>
    </view>

    <!-- 功能菜单（未登录也可访问） -->
    <view class="section-group" style="margin-top: 48rpx;">
      <view class="group-title">
        <view class="group-title-bar"></view>
        <text class="group-title-text">我的服务</text>
      </view>
      <view class="menu-card">
        <view wx:for="{{menuItems}}" wx:key="label" class="menu-item {{index < menuItems.length - 1 ? 'menu-item-border' : ''}}" bindtap="onMenuTap" data-action="{{item.action}}">
          <view class="menu-item-left">
            <view class="menu-icon-wrap">
              <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="menu-label">{{item.label}}</text>
          </view>
          <image class="menu-arrow" src="/assets/icons/chevron-right-secondary.svg" mode="aspectFit" />
        </view>
      </view>
    </view>

    <view class="version-text">
      <text>Music Studio v1.0.0</text>
    </view>
  </block>

  <!-- 已登录态 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-card-inner">
        <view class="avatar-wrap">
          <view class="avatar">
            <image wx:if="{{avatarUrl}}" class="avatar-full-img" src="{{avatarUrl}}" mode="aspectFill" />
            <text wx:else class="avatar-text">{{avatarText}}</text>
          </view>
          <view class="avatar-gold-ring"></view>
        </view>
        <view class="user-info">
          <text class="user-name">{{nickName || studentNo || '未设置姓名'}}</text>
          <text class="user-id">学员ID：{{studentNo}}</text>
          <view class="user-tag" wx:if="{{specialty}}">
            <text class="user-tag-text">{{specialty}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 课时统计 -->
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-num">{{totalLessons}}</text>
        <text class="stats-label">购买课时</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num">{{usedLessons}}</text>
        <text class="stats-label">已上课时</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num gold">{{remainingLessons}}</text>
        <text class="stats-label">剩余课时</text>
      </view>
    </view>

    <!-- 我的课包 -->
    <view class="section-group" wx:if="{{package}}">
      <view class="group-title">
        <view class="group-title-bar"></view>
        <text class="group-title-text">我的课包</text>
      </view>
      <view class="package-card">
        <view class="gold-bar"></view>
        <view class="package-body">
          <view class="package-top">
            <text class="package-name">{{package.name}}</text>
            <view class="package-badge">
              <text class="package-badge-text">进行中</text>
            </view>
          </view>
          <view class="package-meta">
            <text class="package-meta-text">{{package.totalLessons}}节 · 有效期至 {{package.expireDate}}</text>
          </view>
          <view class="package-progress-bar">
            <view class="package-progress-fill" style="width: {{packageProgress}}%;"></view>
          </view>
          <view class="package-progress-label">
            <text class="progress-label-text">已使用 {{package.usedLessons}} 节</text>
            <text class="progress-label-text">剩余 {{remainingLessons}} 节</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="section-group">
      <view class="group-title">
        <view class="group-title-bar"></view>
        <text class="group-title-text">我的服务</text>
      </view>
      <view class="menu-card">
        <view wx:for="{{menuItems}}" wx:key="label" class="menu-item {{index < menuItems.length - 1 ? 'menu-item-border' : ''}}" bindtap="onMenuTap" data-action="{{item.action}}">
          <view class="menu-item-left">
            <view class="menu-icon-wrap">
              <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="menu-label">{{item.label}}</text>
          </view>
          <image class="menu-arrow" src="/assets/icons/chevron-right-secondary.svg" mode="aspectFit" />
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="handleLogout">
      <text class="logout-text">退出登录</text>
    </view>

    <view class="version-text">
      <text>Music Studio v1.0.0</text>
    </view>
  </block>

  <view class="tab-bar-placeholder"></view>
</view>
