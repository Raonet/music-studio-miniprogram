.page {
  background-color: #1A1A1F;
  min-height: 100vh;
}

.tabs {
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding: 32rpx 48rpx;
  border-bottom: 1rpx solid #2E2D35;
}

.tab-item {
  position: relative;
  padding-bottom: 16rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #A89F8C;
}

.tab-text-active {
  color: #C9A84C;
}

.tab-underline {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background-color: #C9A84C;
  border-radius: 4rpx;
}

.record-list {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding-bottom: 48rpx;
}

.record-card {
  background-color: #22222A;
  border-radius: 32rpx;
  border: 1rpx solid #2E2D35;
  overflow: hidden;
  display: flex;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.4);
}

.gold-bar {
  width: 8rpx;
  background: linear-gradient(180deg, #E2C07A, #C9A84C);
  flex-shrink: 0;
}

.record-body {
  flex: 1;
  padding: 40rpx 40rpx 40rpx 32rpx;
}

.record-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  margin-right: 24rpx;
}

.record-course {
  font-size: 32rpx;
  color: #F0EDE6;
  font-weight: 500;
}

.record-date-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.calendar-icon {
  width: 24rpx;
  height: 24rpx;
}

.record-date {
  font-size: 24rpx;
  color: #A89F8C;
}

/* 状态 chip */
.status-chip {
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.status-chip.status-pending {
  background-color: rgba(201,168,76,0.15);
}

.status-chip.status-approved {
  background-color: rgba(76,175,125,0.2);
}

.status-chip.status-rejected {
  background-color: rgba(224,90,90,0.15);
}

.status-text {
  font-size: 22rpx;
}

.status-chip.status-pending .status-text { color: #C9A84C; }
.status-chip.status-approved .status-text { color: #4CAF7D; }
.status-chip.status-rejected .status-text { color: #E05A5A; }

/* 请假原因 */
.record-reason {
  padding: 20rpx 24rpx;
  background-color: rgba(255,255,255,0.03);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border-left: 3rpx solid #2E2D35;
}

.reason-text {
  font-size: 24rpx;
  color: #A89F8C;
  line-height: 1.6;
}

/* 底部提交时间 */
.record-bottom {
  display: flex;
  align-items: center;
}

.submitted-text {
  font-size: 22rpx;
  color: #5A5550;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: 24rpx;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #5A5550;
}

.tab-bar-placeholder {
  height: 48rpx;
}
