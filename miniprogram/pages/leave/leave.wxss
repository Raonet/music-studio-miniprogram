.page {
  background-color: #1A1A1F;
  min-height: 100vh;
  padding: 32rpx 48rpx;
}

.form-card {
  background-color: #22222A;
  border-radius: 32rpx;
  border: 1rpx solid #2E2D35;
  overflow: hidden;
  margin-bottom: 48rpx;
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.6);
}

.gold-top-bar {
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #C9A84C, transparent);
}

.form-body {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #F0EDE6;
}

.picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: #1A1A1F;
  border: 1rpx solid #2E2D35;
  border-radius: 24rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #F0EDE6;
  flex: 1;
}

.picker-text.placeholder {
  color: #5A5550;
}

.picker-arrow, .picker-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.reason-input {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 32rpx;
  background-color: #1A1A1F;
  border: 1rpx solid #2E2D35;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #F0EDE6;
  box-sizing: border-box;
}

.textarea-placeholder {
  color: #5A5550;
  font-size: 28rpx;
}

/* Policy card */
.policy-card {
  background-color: #22222A;
  border-radius: 32rpx;
  border: 1rpx solid #2E2D35;
  padding: 48rpx;
  margin-bottom: 48rpx;
}

.policy-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.info-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: rgba(201,168,76,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
}

.policy-title {
  font-size: 32rpx;
  color: #F0EDE6;
  font-weight: 500;
}

.policy-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-left: 72rpx;
}

.policy-item {
  display: flex;
  gap: 16rpx;
}

.policy-num {
  font-size: 24rpx;
  color: #C9A84C;
  flex-shrink: 0;
}

.policy-text {
  font-size: 24rpx;
  color: #A89F8C;
  line-height: 1.6;
}

/* Submit button */
.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #C9A84C, #E2C07A);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(201,168,76,0.3);
}

.submit-btn-disabled {
  opacity: 0.5;
  box-shadow: none;
}

.submit-text {
  font-size: 32rpx;
  color: #1A1A1F;
  font-weight: 600;
}

.tab-bar-placeholder {
  height: 48rpx;
}
