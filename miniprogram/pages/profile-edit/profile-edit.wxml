<navbar title="个人资料" showBack="{{true}}"></navbar>

<view class="page">
  <!-- 头像 -->
  <view class="section">
    <view class="avatar-edit" bindtap="chooseAvatar">
      <view class="avatar-wrap">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-placeholder-text">{{nickName ? nickName[0] : '学'}}</text>
        </view>
      </view>
      <view class="avatar-edit-badge">
        <text class="avatar-edit-icon">✎</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="field-item">
      <text class="field-label">姓名</text>
      <input
        class="field-input"
        placeholder="请输入姓名"
        placeholder-class="field-placeholder"
        value="{{nickName}}"
        bindinput="onNickNameInput"
      />
    </view>
    <view class="field-divider" />

    <view class="field-item">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="field-placeholder"
        value="{{contactPhone}}"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="field-divider" />

    <view class="field-item">
      <text class="field-label">性别</text>
      <picker
        class="field-picker"
        mode="selector"
        range="{{genderOptions}}"
        range-key="label"
        value="{{gender}}"
        bindchange="onGenderChange"
      >
        <view class="picker-value">
          <text>{{genderOptions[gender].label}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 学习方向 -->
  <view class="section-title">学习方向（可多选）</view>
  <view class="card">
    <view wx:if="{{specialtyOptions.length === 0}}" class="empty-dict">
      <text class="empty-dict-text">暂无选项，请在后台「字典管理」中添加 musicSpecialty 字典</text>
    </view>
    <view class="specialty-grid">
      <view
        wx:for="{{specialtyOptions}}"
        wx:key="value"
        class="specialty-tag {{specialtyArr.indexOf(item.value) >= 0 ? 'specialty-tag-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onSpecialtyToggle"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn {{saving ? 'save-btn-disabled' : ''}}" bindtap="onSave">
    <text class="save-btn-text">{{saving ? '保存中...' : '保存'}}</text>
  </button>

  <view class="tab-bar-placeholder" />
</view>
