.page {
  background-color: #1A1A1F;
  min-height: 100vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
  position: relative;
}

.empty-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background-color: #C9A84C;
  border-radius: 50%;
  opacity: 0.06;
  filter: blur(40rpx);
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  opacity: 0.3;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #A89F8C;
}

.tab-bar-placeholder {
  height: 130rpx;
}
